# ─── Anthropic / Claude API ────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Football Stats API ────────────────────────────────────────────────────
# Option A — Direct API-Football key (api-sports.io)
#   Sign up at: https://dashboard.api-football.com/
#   Free tier: 100 requests/day
API_FOOTBALL_KEY=your_api_sports_key_here

# Option B — RapidAPI key (api-football on RapidAPI marketplace)
#   Sign up at: https://rapidapi.com/api-sports/api/api-football
#   Use EITHER API_FOOTBALL_KEY or RAPIDAPI_KEY, not both.
# RAPIDAPI_KEY=your_rapidapi_key_here
